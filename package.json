{
  "name": "arduino-circuit-visualizer",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop Arduino circuit designer for planning, learning, and documentation.",
  "author": "OpenAI Codex",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 dist-electron/main/index.js dist-electron/preload/index.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "electron:launch": "wait-on tcp:5173 dist-electron/main/index.js dist-electron/preload/index.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "electron:build": "vite build && tsc -p tsconfig.electron.json && node scripts/run-electron-builder.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "verify:sketch": "node scripts/verify-sketch-generator.mjs",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.codex.arduino-circuit-visualizer",
    "productName": "Arduino Circuit Visualizer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "plugins/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main/index.js"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png",
      "category": "Development"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@monaco-editor/react": "^4.7.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.7.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "lucide-react": "^0.553.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "reactflow": "^11.11.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.1.11",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  }
}
